{
  "title": "Forex AI — System Health",
  "uid": "forex-system",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"fastapi\"}[1m])",
          "legendFormat": "{{method}} {{handler}} {{status_code}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "title": "HTTP P95 Latency",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"fastapi\"}[1m]))",
          "legendFormat": "p95 {{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 3,
      "title": "HTTP Error Rate (4xx + 5xx)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"fastapi\",status_code=~\"[45]..\"}[1m])",
          "legendFormat": "{{status_code}} {{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "fixedColor": "red", "mode": "fixed" } }
      }
    },
    {
      "id": 4,
      "title": "Celery Active Tasks",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "celery_workers_active_tasks_total",
          "legendFormat": "Active"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 3 },
            { "color": "red", "value": 8 }
          ]
        }}
      }
    },
    {
      "id": 5,
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "process_start_time_seconds{job=\"fastapi\"}",
          "legendFormat": "FastAPI started"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "dateTimeAsIso" }
      }
    }
  ]
}
