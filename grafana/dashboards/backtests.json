{
  "title": "Forex AI — Backtests",
  "uid": "forex-backtests",
  "schemaVersion": 38,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Backtest Jobs / min",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"fastapi\",handler=\"/api/backtest\",method=\"POST\"}[1m])",
          "legendFormat": "dispatched"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 2,
      "title": "Backtest Endpoint Latency (p95)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"fastapi\",handler=~\"/api/backtest.*\"}[5m]))",
          "legendFormat": "p95 {{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 3,
      "title": "Analytics API Calls / min",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"fastapi\",handler=~\"/api/analytics.*\"}[1m])",
          "legendFormat": "{{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 4,
      "title": "Copilot Chat Calls / min",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"fastapi\",handler=\"/api/copilot/chat\",method=\"POST\"}[1m])",
          "legendFormat": "chat"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    }
  ]
}
